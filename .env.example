# =============================================================================
# AAA (Algorithmic Alpha Advisor) — 환경 변수 템플릿
# =============================================================================
#
# 이 파일은 네 개의 .env 파일 템플릿을 포함합니다:
#   1. 프로젝트 루트 .env       — Docker Compose 변수 보간용
#   2. .env.common              — 앱 서비스 전용 (인프라 컨테이너에 주지 않음)
#   3. .env.mysql               — MySQL 컨테이너 전용
#   4. .env.redis               — Redis 컨테이너 전용
#
# 서비스별 변수(.env.collector, .env.analyzer 등)는 각 서비스 레포의
# .env.example에서 관리한다. (ADR-006 참조)
#
# 보안:
#   chmod 600 ${AAA_SSD_BASE}/secrets/.env.*
#
# 비밀번호 생성:
#   openssl rand -hex 24
#   → hex(0-9, a-f)만 사용하여 .env 파싱·Redis ACL·MySQL 모두 호환
#   → 48자, 192비트 엔트로피
#   → 각 비밀번호마다 별도 실행하여 독립된 값 사용
#
# =============================================================================


# -----------------------------------------------------------------------------
# 섹션 1: 프로젝트 루트 .env — Docker Compose 변수 보간
# -----------------------------------------------------------------------------
# 경로: aaa-infra/.env (docker-compose.yml과 같은 디렉토리)

# NAS SSD 볼륨 베이스 경로
AAA_SSD_BASE=<nas-ssd-mount-path>

# NAS HDD 볼륨 베이스 경로
AAA_HDD_BASE=<nas-hdd-mount-path>

# -----------------------------------------------------------------------------
# 섹션 2: .env.common — 앱 서비스 전용
# -----------------------------------------------------------------------------
# 경로: ${AAA_SSD_BASE}/secrets/.env.common
# 대상: collector, analyzer, notifier, trader (인프라 컨테이너에 주지 않음)

TZ=Asia/Seoul
MYSQL_HOST=aaa-mysql
MYSQL_PORT=3306
MYSQL_DATABASE=aaa
REDIS_HOST=aaa-redis
REDIS_PORT=6379
REDIS_APPUSER_PASSWORD=<openssl rand -hex 24>


# -----------------------------------------------------------------------------
# 섹션 3: .env.mysql — MySQL 컨테이너 전용
# -----------------------------------------------------------------------------
# 경로: ${AAA_SSD_BASE}/secrets/.env.mysql

TZ=Asia/Seoul
MYSQL_ROOT_PASSWORD=<openssl rand -hex 24>
MYSQL_DATABASE=aaa
# 서비스별 비밀번호는 해당 Phase 착수 시 추가
# MYSQL_COLLECTOR_PASSWORD=<openssl rand -hex 24>    (Phase 1)
# MYSQL_ANALYZER_PASSWORD=<openssl rand -hex 24>     (Phase 2)
# MYSQL_NOTIFIER_PASSWORD=<openssl rand -hex 24>     (Phase 3)
# MYSQL_TRADER_PASSWORD=<openssl rand -hex 24>        (Phase 4)


# -----------------------------------------------------------------------------
# 섹션 4: .env.redis — Redis 컨테이너 전용
# -----------------------------------------------------------------------------
# 경로: ${AAA_SSD_BASE}/secrets/.env.redis

TZ=Asia/Seoul
REDIS_ADMIN_PASSWORD=<openssl rand -hex 24>
# REDISCLI_AUTH: redis-cli가 비밀번호를 자동으로 읽는 환경 변수.
# 컨테이너 healthcheck에서 -a 플래그 없이 인증하기 위해 REDIS_ADMIN_PASSWORD와 동일값으로 설정.
# 주의: REDISCLI_AUTH와 REDIS_ADMIN_PASSWORD가 불일치하면 Redis healthcheck가 실패합니다.
REDISCLI_AUTH=<위 REDIS_ADMIN_PASSWORD와 반드시 동일한 값을 복사>
REDISCLI_AUTH_USER=admin


# -----------------------------------------------------------------------------
# 서비스별 변수 안내
# -----------------------------------------------------------------------------
# 각 서비스 전용 변수(.env.collector, .env.analyzer, .env.notifier, .env.trader)는
# 해당 서비스 레포의 .env.example에서 관리한다.
# 경로: ${AAA_SSD_BASE}/secrets/.env.<서비스명>
# 참조: ADR-006, TECHSPEC 3.8절
